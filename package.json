{
  "name": "datazen",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "e2e": "node e2e/run.mjs",
    "e2e:skip-build": "node e2e/run.mjs --skip-build",
    "e2e:wdio": "wdio run e2e/wdio.conf.ts",
    "e2e:core": "node e2e/run.mjs --skip-build -- --spec e2e/specs/main-window.ts,e2e/specs/new-connection.ts,e2e/specs/edit-delete-connection.ts,e2e/specs/connection-search-group.ts,e2e/specs/settings.ts,e2e/specs/i18n-menu.ts,e2e/specs/homepage-features.ts,e2e/specs/drag-drop-groups.ts,e2e/specs/backup-database.ts",
    "e2e:db": "node e2e/run.mjs --skip-build -- --spec e2e/specs/connection-window.ts,e2e/specs/sql-query.ts,e2e/specs/table-data.ts,e2e/specs/table-edit.ts,e2e/specs/table-structure.ts,e2e/specs/export-import.ts,e2e/specs/data-types.ts,e2e/specs/mysql.ts,e2e/specs/data-sync-real.ts",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-virtual": "^3.13.6",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.2.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.487.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.9.0",
    "expect-webdriverio": "^5.6.5",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "vitest": "^4.1.4"
  }
}
